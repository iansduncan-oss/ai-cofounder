{
  "name": "ai-cofounder",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config apps/agent-server/vitest.integration.config.ts",
    "clean": "turbo run clean",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:push": "npm run db:push -w @ai-cofounder/db",
    "db:generate": "npm run db:generate -w @ai-cofounder/db",
    "db:migrate": "npm run db:migrate -w @ai-cofounder/db",
    "db:studio": "npm run db:studio -w @ai-cofounder/db",
    "db:seed": "npm run db:seed -w @ai-cofounder/db",
    "productivity:setup": "bash scripts/setup-productivity.sh",
    "deploy:dry-run": "gh workflow run deploy.yml -f dry_run=true",
    "memory-bridge:sync": "tsx scripts/sync-memory-bridge.ts",
    "prepare": "node -e \"try{require('child_process').execSync('husky',{stdio:'inherit'})}catch(e){}\""
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "npm@11.6.2",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.60.2",
    "@rollup/rollup-linux-x64-gnu": "^4.60.2",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "lightningcss-linux-arm64-musl": "^1.32.0",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.4",
    "@tailwindcss/oxide-linux-arm64-musl": "^4.2.2"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "cheerio": {
      "undici": "^7.24.0"
    },
    "discord.js": {
      "undici": "^6.24.0"
    },
    "hono": "^4.12.14",
    "follow-redirects": "^1.16.0",
    "fast-jwt": "^6.2.0",
    "lodash-es": "^4.18.0",
    "vite": "^6.4.2",
    "yaml": "^2.8.3",
    "picomatch": "^4.0.4",
    "brace-expansion": "^5.0.5",
    "path-to-regexp": "^8.4.0",
    "drizzle-kit": {
      "@esbuild-kit/esm-loader": {
        "@esbuild-kit/core-utils": {
          "esbuild": "^0.25.0"
        }
      }
    }
  },
  "dependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.2.4",
    "axios": "^1.15.2",
    "fastify": "^5.8.5",
    "lightningcss-darwin-arm64": "^1.32.0"
  }
}
