# Authentik — environment variables
#
# Copy to .env in this directory and fill in the values, or (preferred)
# export them from /opt/ai-cofounder/.env so they come from the same
# place as the rest of the stack.
#
# Generate secrets:
#   AUTHENTIK_SECRET_KEY       openssl rand -base64 60 | tr -d '\n'
#   AUTHENTIK_POSTGRES_PASSWORD  openssl rand -hex 32
#   AUTHENTIK_BOOTSTRAP_PASSWORD openssl rand -base64 24
#   AUTHENTIK_BOOTSTRAP_TOKEN    openssl rand -hex 32   (optional — lets you hit the API immediately)

AUTHENTIK_SECRET_KEY=
AUTHENTIK_POSTGRES_PASSWORD=
AUTHENTIK_BOOTSTRAP_EMAIL=ian@aviontechs.com
AUTHENTIK_BOOTSTRAP_PASSWORD=
AUTHENTIK_BOOTSTRAP_TOKEN=

# Optional SMTP — leave blank to disable email (Authentik will still
# work, but password resets and MFA enrollment via email are disabled).
AUTHENTIK_SMTP_HOST=
AUTHENTIK_SMTP_PORT=587
AUTHENTIK_SMTP_USER=
AUTHENTIK_SMTP_PASSWORD=
AUTHENTIK_SMTP_FROM=jarvis@aviontechs.com
