{
  "uid": "youtube-analytics",
  "title": "YouTube Analytics",
  "description": "YouTube channel performance metrics and video analytics",
  "tags": ["youtube", "analytics"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["ai-cofounder"],
      "targetBlank": false,
      "title": "AI Cofounder Dashboards",
      "tooltip": "Navigate to other dashboards",
      "type": "dashboards"
    }
  ],
  "refresh": "5m",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "weekStart": "",
  "templating": {
    "list": [
      {
        "name": "channel",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "youtube-analytics-pg"
        },
        "definition": "SELECT DISTINCT channel FROM videos ORDER BY channel",
        "query": "SELECT DISTINCT channel FROM videos ORDER BY channel",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Views",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT total_views AS \"Total Views\" FROM channel_metrics WHERE channel IN ($channel) ORDER BY collected_at DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Subscribers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 100 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT subscribers AS \"Subscribers\" FROM channel_metrics WHERE channel IN ($channel) ORDER BY collected_at DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Videos",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT total_videos AS \"Total Videos\" FROM channel_metrics WHERE channel IN ($channel) ORDER BY collected_at DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg Like Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 5 }
            ]
          },
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT ROUND(AVG(CASE WHEN views > 0 THEN likes::numeric / views * 100 ELSE 0 END), 2) AS \"Avg Like Rate\" FROM video_performance WHERE snapshot_type = 'latest' AND channel IN ($channel)",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Video Views over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT snapshot_at AS time, title AS metric, views AS value FROM video_performance WHERE snapshot_type = 'latest' AND channel IN ($channel) ORDER BY snapshot_at ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Like Rate by Video",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "barWidth": 0.8,
        "groupWidth": 0.7,
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT title AS \"Video\", ROUND(CASE WHEN views > 0 THEN likes::numeric / views * 100 ELSE 0 END, 2) AS \"Like Rate %\" FROM video_performance WHERE snapshot_type = 'latest' AND channel IN ($channel) ORDER BY \"Like Rate %\" DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Top Performing Videos",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Views" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "Likes" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "Comments" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "Like Rate %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Published" },
            "properties": [
              { "id": "unit", "value": "dateTimeAsIso" },
              { "id": "custom.width", "value": 160 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Views", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT vp.title AS \"Title\", vp.views AS \"Views\", vp.likes AS \"Likes\", vp.comments AS \"Comments\", ROUND(CASE WHEN vp.views > 0 THEN vp.likes::numeric / vp.views * 100 ELSE 0 END, 2) AS \"Like Rate %\", vp.published_at AS \"Published\" FROM video_performance vp WHERE vp.snapshot_type = 'latest' AND vp.channel IN ($channel) ORDER BY vp.views DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Views by Category",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": true
        },
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT va.category AS \"Category\", SUM(vp.views) AS \"Views\" FROM video_attributes va JOIN video_performance vp ON va.video_id = vp.video_id WHERE vp.snapshot_type = 'latest' AND vp.channel IN ($channel) GROUP BY va.category ORDER BY \"Views\" DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Publishing Cadence",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "pointSize": 5,
            "showPoints": "never"
          },
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "short",
          "displayName": "Videos Published"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT date_trunc('week', published_at) AS time, COUNT(*) AS \"Videos\" FROM videos WHERE channel IN ($channel) GROUP BY date_trunc('week', published_at) ORDER BY time ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Channel Growth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "pointSize": 5,
            "showPoints": "auto"
          },
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "short",
          "displayName": "Subscribers"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT collected_at AS time, subscribers AS value FROM channel_metrics WHERE channel IN ($channel) ORDER BY collected_at ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Script Score vs Views",
      "type": "xychart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "seriesMapping": "auto",
        "dims": {
          "x": "Script Score",
          "exclude": ["Title"]
        },
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "youtube-analytics-pg" },
          "rawSql": "SELECT va.script_score AS \"Script Score\", vp.views AS \"Views\", vp.title AS \"Title\" FROM video_attributes va JOIN video_performance vp ON va.video_id = vp.video_id WHERE vp.snapshot_type = 'latest' AND va.script_score IS NOT NULL AND vp.channel IN ($channel) ORDER BY va.script_score ASC",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
