          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"avion\"} / (pg_stat_database_blks_hit{datname=\"avion\"} + pg_stat_database_blks_read{datname=\"avion\"})",
          "legendFormat": "Cache Hit %",
          "refId": "A"
        }
      ]
    },
