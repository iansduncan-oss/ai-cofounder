# VPS automation scripts environment
# Copy to .env and fill in values
DISCORD_NOTIFICATION_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: Override agent-server URL (default: http://localhost:3100)
# AGENT_SERVER_URL=http://localhost:3100

# Optional: Send success heartbeat notifications (default: false)
# HEARTBEAT_ENABLED=true
