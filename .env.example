# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=ai_cofounder
POSTGRES_PASSWORD=localdev
POSTGRES_DB=ai_cofounder
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ai_cofounder:localdev@localhost:5432/ai_cofounder

# ── n8n ───────────────────────────────────────────────────
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=localdev

# ── Agent Server ──────────────────────────────────────────
PORT=3100
HOST=0.0.0.0
LOG_LEVEL=info

# ── Security ─────────────────────────────────────────────
# Set API_SECRET to require Bearer token auth on /api/* routes
# Leave blank to disable auth (dev mode only!)
API_SECRET=
# Rate limiting: max requests per window per IP
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60

# ── Claude API ────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Model for specialist agents (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Lightweight model for message routing (default: claude-haiku-3-20240307)
# ANTHROPIC_ROUTER_MODEL=claude-haiku-3-20240307

# ── Discord Bot (for Task 3) ─────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
AGENT_SERVER_URL=http://localhost:3100

# ── Token Limits ────────────────────────────────────────
DAILY_TOKEN_LIMIT=100000
