# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=ai_cofounder
POSTGRES_PASSWORD=localdev
POSTGRES_DB=ai_cofounder
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ai_cofounder:localdev@localhost:5432/ai_cofounder

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── n8n ───────────────────────────────────────────────────
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=localdev

# ── Agent Server ──────────────────────────────────────────
PORT=3100
HOST=0.0.0.0
LOG_LEVEL=info

# ── Dashboard ────────────────────────────────────────────
# API URL for dashboard (leave blank in production — served same-origin by agent-server)
# VITE_API_URL=http://localhost:3100

# ── Authentication ────────────────────────────────────────
# JWT secret for dashboard auth (required in production)
# JWT_SECRET=
# Cookie secret for HttpOnly refresh cookies (required in production)
# COOKIE_SECRET=
# Admin account auto-created on first startup
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=

# ── Security ─────────────────────────────────────────────
# Set API_SECRET to require Bearer token auth on /api/* routes (used by bots)
# Leave blank to disable auth (dev mode only!)
API_SECRET=
# Rate limiting: max requests per window per IP
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60
# Tighter limit for LLM endpoints (/api/agents/run, /api/n8n/webhook, /api/goals/)
# RATE_LIMIT_EXPENSIVE_MAX=10

# ── CORS (comma-separated allowed origins, blank = allow all in dev) ──
# CORS_ORIGINS=

# ── LLM Providers ────────────────────────────────────────
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Groq — free tier at https://console.groq.com
# GROQ_API_KEY=

# Google AI Studio — free tier at https://aistudio.google.com
# GEMINI_API_KEY=

# OpenRouter — free models at https://openrouter.ai
# OPENROUTER_API_KEY=

# ── Discord Bot (for Task 3) ─────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
AGENT_SERVER_URL=http://localhost:3100

# ── Discord Guild (optional, for instant slash command registration)
# DISCORD_GUILD_ID=
# Health check port for Discord bot (default: 3101)
# DISCORD_HEALTH_PORT=3101

# ── Slack Bot ───────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=
# SLACK_APP_TOKEN=xapp-...
# SLACK_BOT_PORT=3200
# Health check port for Slack bot (default: 3102)
# SLACK_HEALTH_PORT=3102
# Channel ID for proactive approval notifications (agent-server uses SLACK_BOT_TOKEN to post)
# SLACK_NOTIFICATION_CHANNEL=C0123456789

# ── n8n Integration ──────────────────────────────────────
# Shared secret for authenticating n8n ↔ agent-server webhooks
# N8N_SHARED_SECRET=
# Timeout for outbound n8n webhook calls (default: 30000ms)
# N8N_WEBHOOK_TIMEOUT_MS=30000

# ── Web Search (Tavily) ─────────────────────────────────
# TAVILY_API_KEY=

# ── Proactive Notifications ───────────────────────────
# Discord webhook for goal completion, task failure, and progress notifications
# Can be the same webhook as DISCORD_FOLLOWUP_WEBHOOK_URL or a separate channel
# DISCORD_NOTIFICATION_WEBHOOK_URL=

# ── Proactive Scheduler ───────────────────────────────
# Discord webhook for scheduler messages (briefings, stale goal check-ins)
# DISCORD_FOLLOWUP_WEBHOOK_URL=
# Hour (0-23) to send daily briefings (default: 9)
# BRIEFING_HOUR=9
# IANA timezone for briefing schedule (default: UTC)
# BRIEFING_TIMEZONE=UTC

# ── OpenTelemetry ────────────────────────────────────────
# OTLP endpoint for trace export (e.g. http://localhost:4318 for Grafana Tempo)
# Leave blank to use console exporter in dev, disable in prod
# OTEL_EXPORTER_OTLP_ENDPOINT=

# ── GitHub ────────────────────────────────────────────────
# Personal access token for creating PRs via the create_pr tool
# Requires 'repo' scope. Leave blank to disable PR creation.
# GITHUB_TOKEN=

# Secret for verifying GitHub webhook signatures (HMAC SHA-256)
# Leave blank to skip verification (dev mode only!)
# GITHUB_WEBHOOK_SECRET=

# Comma-separated list of repos to monitor (e.g. "owner/repo1,owner/repo2")
# GITHUB_MONITORED_REPOS=

# ── VPS Monitoring ──────────────────────────────────────────
# SSH host and user for VPS health checks
# VPS_HOST=
# VPS_USER=

# ── ElevenLabs TTS ──────────────────────────────────────
# API key for ElevenLabs text-to-speech (JARVIS voice)
# ELEVENLABS_API_KEY=
# Voice ID — default "Adam" (pNInz6obpgDQGcFmaJgB). Browse at https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# Model ID — default "eleven_turbo_v2_5" (fast, good quality)
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ── Google OAuth (optional — enables "Sign in with Google" on dashboard) ──
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3100/api/auth/google/callback

# ── Token Encryption ──────────────────────────────────────
# 64-char hex string (32 bytes) for encrypting stored OAuth tokens at rest
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production when Google OAuth is enabled
# TOKEN_ENCRYPTION_KEY=

# ── Browser Automation (Playwright) ──────────────────────
# Path to Chromium executable (auto-detected if not set; required in Docker)
# BROWSER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Max concurrent browser contexts (default: 3)
# BROWSER_MAX_CONTEXTS=3

# ── Memory Lifecycle (v3.1) ───────────────────────────
# Decay rate for memory relevance scoring (default: 0.05)
# MEMORY_DECAY_RATE=0.05
# Max memory budget per user in tokens (default: 10000)
# MEMORY_BUDGET_PER_USER=10000
# Enable chokidar file watcher for RAG auto-ingestion (default: false)
# ENABLE_FILE_WATCHER=false

# ── Token Limits ────────────────────────────────────────
DAILY_TOKEN_LIMIT=100000

# ── Budget Enforcement ────────────────────────────────
# Daily/weekly USD spending limits (triggers alerts when exceeded)
# DAILY_BUDGET_USD=10
# WEEKLY_BUDGET_USD=50

# ── Autonomous Sessions ──────────────────────────────
# Interval between autonomous session runs (minutes, default: 60)
# AUTONOMOUS_SESSION_INTERVAL_MINUTES=60
# Token budget per session (default: unlimited)
# SESSION_TOKEN_BUDGET=50000
# Time budget per session in milliseconds (default: unlimited)
# SESSION_TIME_BUDGET_MS=300000

# ── DAG Task Execution ──────────────────────────────
# Max concurrent tasks in DAG-based parallel execution (default: 3)
# MAX_TASK_CONCURRENCY=3

# ── Workspace ────────────────────────────────────────
# Directory for file/git workspace operations (default: /tmp/ai-cofounder-workspace)
# WORKSPACE_DIR=/tmp/ai-cofounder-workspace

# ── n8n API ──────────────────────────────────────────
# Direct n8n API access (for workflow management tools)
# N8N_BASE_URL=http://localhost:5678
# N8N_API_KEY=

# ── GitHub Repo (for PR/CI tools) ────────────────────
# GITHUB_REPO_OWNER=
# GITHUB_REPO_NAME=
# GITHUB_DEFAULT_BRANCH=main

# ── Deploy Observability ─────────────────────────────
# Webhook secret for validating deploy status callbacks
# DEPLOY_WEBHOOK_SECRET=
# URL for deploy health check verification
# DEPLOY_HEALTH_URL=http://localhost:3100/health/deep
# Dead-letter queue alert threshold (default: 10)
# DLQ_ALERT_THRESHOLD=10
