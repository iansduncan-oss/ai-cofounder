# ── AI Cofounder — Production Environment ──────────────────
# Copy to .env on your VPS at /opt/ai-cofounder/.env
# All variables below are REQUIRED unless marked optional.

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://ai_cofounder:CHANGE_ME@localhost:5432/ai_cofounder

# ── Agent Server ─────────────────────────────────────────────
PORT=3100
HOST=0.0.0.0
LOG_LEVEL=warn

# ── Security (REQUIRED for production) ──────────────────────
# Generate with: openssl rand -base64 32
API_SECRET=CHANGE_ME_MIN_32_CHARS
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60

# ── CORS (comma-separated allowed origins) ──────────────────
# Leave empty to block all cross-origin requests
CORS_ORIGINS=https://aviontechs.com

# ── Claude API ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override default model
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Discord Bot ─────────────────────────────────────────────
DISCORD_TOKEN=MTQ3ODU3...
DISCORD_CLIENT_ID=1478571582...

# ── Token Limits ────────────────────────────────────────────
DAILY_TOKEN_LIMIT=100000

# ── n8n Workflow Automation ────────────────────────────────
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME
# PostgreSQL host — use container name if on same Docker network,
# or host.docker.internal if Postgres runs on the host
N8N_DB_HOST=host.docker.internal
N8N_DB_USER=ai_cofounder
N8N_DB_PASSWORD=CHANGE_ME
# Optional: timezone for n8n (default UTC)
# TZ=America/New_York

# ── Monitoring (optional) ───────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# GRAFANA_ROOT_URL=https://grafana.aviontechs.com
