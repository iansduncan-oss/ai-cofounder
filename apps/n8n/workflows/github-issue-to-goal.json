      "parameters": {
        "method": "POST",
        "url": "=https://api.github.com/repos/{{ $('Classify Issue').item.json._repo }}/issues/{{ $('Classify Issue').item.json.number }}/comments",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ body: 'Thanks for your question! 👋\\n\\nHere are some resources that might help:\\n- [Documentation](https://github.com/' + $('Classify Issue').item.json._repo + '#readme)\\n- [Existing Discussions](https://github.com/' + $('Classify Issue').item.json._repo + '/issues?q=is%3Aissue+label%3Aquestion)\\n\\nA team member will follow up if more context is needed.' }) }}",
        "options": {}
      },
      "id": "auto-reply-question",
      "name": "Auto-Reply to Question",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1350, 600],
      "credentials": {
        "httpHeaderAuth": {
          "id": "github-token",
          "name": "GitHub Token"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Merge node — collects results from all 3 branches\n// Determine which branch produced this result\nconst classify = $('Classify Issue').item.json;\nconst type = classify._type;\n\nconst badges = { bug: '🐛 Bug', feature: '✨ Feature', question: '❓ Question' };\nconst colors = { bug: 15548997, feature: 3447003, question: 16776960 };\n\nconst embed = {\n  title: `${badges[type] || '📋 Issue'}: ${classify.title}`,\n  description: (classify.body || 'No description').substring(0, 200),\n  url: classify.html_url,\n  color: colors[type] || 3447003,\n  timestamp: new Date().toISOString(),\n  fields: [\n    { name: 'Type', value: type, inline: true },\n    { name: 'Issue', value: `#${classify.number}`, inline: true },\n    { name: 'Author', value: classify.user?.login || 'unknown', inline: true },\n  ],\n  footer: { text: `Classified by n8n pipeline` },\n};\n\nif (type === 'bug') {\n  const dupCount = 0; // Will be enriched if available\n  embed.fields.push({ name: 'Action', value: 'High-priority goal created, labeled `bug`', inline: false });\n} else if (type === 'feature') {\n  embed.fields.push({ name: 'Action', value: 'Medium-priority goal created, labeled `enhancement`', inline: false });\n} else {\n  embed.fields.push({ name: 'Action', value: 'Auto-replied with docs pointer, labeled `question`', inline: false });\n}\n\nreturn [{ json: { embed } }];"
      },
      "id": "format-notification",
      "name": "Format Notification",
      "type": "n8n-nodes-base.code",
