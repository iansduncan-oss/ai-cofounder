{
  "name": "Enhanced GitHub Issue Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "github-issue",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "GitHub Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-action",
              "leftValue": "={{ $json.action }}",
              "rightValue": "opened",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "filter-opened",
      "name": "Filter Opened Issues",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [470, 400]
    },
    {
      "parameters": {
        "jsCode": "const issue = $json.issue;\nconst labels = (issue.labels || []).map(l => l.name.toLowerCase());\nconst title = (issue.title || '').toLowerCase();\nconst body = (issue.body || '').toLowerCase();\nconst text = `${title} ${body}`;\n\n// Label overrides take priority\nif (labels.includes('bug') || labels.includes('defect')) {\n  return [{ json: { ...issue, _type: 'bug', _repo: $json.repository.full_name } }];\n}\nif (labels.includes('enhancement') || labels.includes('feature') || labels.includes('feature-request')) {\n  return [{ json: { ...issue, _type: 'feature', _repo: $json.repository.full_name } }];\n}\nif (labels.includes('question') || labels.includes('help wanted') || labels.includes('support')) {\n  return [{ json: { ...issue, _type: 'question', _repo: $json.repository.full_name } }];\n}\n\n// Keyword heuristics\nconst bugKeywords = ['bug', 'error', 'crash', 'broken', 'fail', 'not working', 'exception', 'regression', 'fix', '500', '404', 'undefined', 'null pointer', 'stack trace'];\nconst featureKeywords = ['feature', 'request', 'add support', 'implement', 'enhancement', 'would be nice', 'proposal', 'rfc', 'new'];\nconst questionKeywords = ['how to', 'how do', 'question', 'help', 'is it possible', 'can i', 'does it', 'documentation', 'example', 'tutorial'];\n\nconst bugScore = bugKeywords.filter(k => text.includes(k)).length;\nconst featureScore = featureKeywords.filter(k => text.includes(k)).length;\nconst questionScore = questionKeywords.filter(k => text.includes(k)).length;\n\nlet type = 'feature'; // default\nif (bugScore > featureScore && bugScore > questionScore) type = 'bug';\nelse if (questionScore > bugScore && questionScore > featureScore) type = 'question';\n\nreturn [{ json: { ...issue, _type: type, _repo: $json.repository.full_name } }];"
      },
      "id": "classify-issue",
      "name": "Classify Issue",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [690, 400]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            {
              "outputKey": "bug",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json._type }}",
                    "rightValue": "bug",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              }
            },
            {
              "outputKey": "feature",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json._type }}",
                    "rightValue": "feature",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              }
            },
            {
              "outputKey": "question",
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json._type }}",
                    "rightValue": "question",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              }
            }
          ]
        },
        "options": {
          "allMatchingOutputs": false
        }
      },
      "id": "switch-type",
      "name": "Switch by Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [910, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.github.com/search/issues?q={{ encodeURIComponent($json.title) }}+repo:{{ $json._repo }}+is:issue+state:open&per_page=5",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 10000
        }
      },
      "id": "check-duplicates",
      "name": "Check Duplicate Bugs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1130, 200],
      "credentials": {
        "httpHeaderAuth": {
          "id": "github-token",
          "name": "GitHub Token"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.github.com/repos/{{ $('Classify Issue').item.json._repo }}/issues/{{ $('Classify Issue').item.json.number }}/labels",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ labels: ['bug'] }) }}",
        "options": {}
      },
      "id": "label-bug",
      "name": "Label Bug",
      "type": "n8n-nodes-base.httpRequest",
