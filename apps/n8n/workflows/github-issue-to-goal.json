        "jsonBody": "={{ JSON.stringify({ message: '[BUG] Create a high-priority goal from this bug report:\\n\\nTitle: ' + $('Classify Issue').item.json.title + '\\nDescription: ' + ($('Classify Issue').item.json.body || 'No description') + '\\nURL: ' + $('Classify Issue').item.json.html_url + (($('Check Duplicate Bugs').item.json.total_count > 1) ? '\\n\\nNote: Possible duplicates found — check existing issues.' : ''), userId: 'n8n-automation', conversationId: 'n8n-github-issues' }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "create-bug-goal",
      "name": "Create Bug Goal",
